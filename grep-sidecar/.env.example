# Server
GREP_PORT=1935

# Data directory to search
GREP_DATA_DIR=/data

# Search timeout
GREP_TIMEOUT=30s

# Max result files per search
GREP_MAX_RESULTS=500

# Max file size ripgrep will scan
GREP_MAX_FILESIZE=50M

# OpenViking path prefix for result transformation
OPEN_VIKING_DATA_PATH=/data/workspace/viking
OPEN_VIKING_ACCOUNT=default

