# Server
SIDECAR_PORT=1935

# Grep
SIDECAR_TIMEOUT=30s
MAX_GREP_RESULTS=500
MAX_GREP_FILESIZE=50M

# OpenViking data path (required)
OPEN_VIKING_DATA_PATH=/app/data/workspace/viking
OPEN_VIKING_ACCOUNT=default

# PVC data root
ROOT_DATA_PATH=/app/data

# Sync — primary pod (set both to enable)
SYNC_SOURCE_DIR=/app/data/primary/
SYNC_DEST_DIRS=/app/data/replica1/,/app/data/replica2/
SYNC_INTERVAL=5m
# SYNC_EXCLUDES=.openviking.pid,temp/,_system/queue/,_system/redo/,log/
